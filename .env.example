# Copie para .env e preencha os valores
# cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=localpass123

# JWT — mínimo 32 caracteres
JWT_KEY=sua-chave-jwt-minimo-32-caracteres-aqui

# Salematic — mesma chave configurada no projeto Salematic
SALEMATIC_JWT_KEY=sua-chave-salematic-aqui

# URL base do Salematic (opcional, default: http://localhost:5000)
# SALEMATIC_BASE_URL=http://host.docker.internal:5000
